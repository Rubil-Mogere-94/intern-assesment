{
  "title": "Logs Dashboard",
  "panels": [
    {
      "title": "Application Log Stream",
      "type": "logs",
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{job=\"kubernetes-pods\"}"
        }
      ]
    },
    {
      "title": "Log Level Trends",
      "type": "graph",
      "targets": [
        {
          "expr": "count_over_time({job=\"kubernetes-pods\"} |= \"error\" [1m])",
          "legendFormat": "Errors"
        }
      ]
    }
  ]
}
