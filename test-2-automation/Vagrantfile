# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Common settings for both VMs
  config.vm.box = "ubuntu/jammy64"   # Ubuntu 22.04

  # Public VM (gateway)
  config.vm.define "public" do |public|
    public.vm.hostname = "gateway"
    public.vm.network "private_network", ip: "192.168.56.10"
    public.vm.network "forwarded_port", guest: 80, host: 8080   # Access nginx from host
    
    # Note: Public network bridge might need adjustment based on host interface
    # public.vm.network "public_network" 

    public.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.cpus = 1
    end

    # Run Ansible provisioner on this VM
    public.vm.provision "ansible" do |ansible|
      ansible.playbook = "ansible/playbook.yml"
      ansible.inventory_path = "ansible/inventory.ini"
      ansible.limit = "all"
    end
  end

  # Private VM (app server)
  config.vm.define "private" do |private|
    private.vm.hostname = "appserver"
    private.vm.network "private_network", ip: "192.168.56.11"

    private.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.cpus = 1
    end
  end
end